DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/financial_assistant
REDIS_URL=redis://redis:6379/0

# Generate a secure SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Recommended: 64+ characters for maximum security
SECRET_KEY=your-secret-key-change-in-production-use-at-least-64-characters-for-security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Twilio webhook signature validation
# In development with proxies/ngrok you can set false, but NEVER in production
TWILIO_VALIDATE_SIGNATURE=false

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_access_token
MERCADO_PAGO_PUBLIC_KEY=your_mercado_pago_public_key

# PayFlow AI payment provider: fake | mercado_pago
# Default is fake (sandbox). Use mercado_pago only with sandbox credentials.
# Demo mode requires PAYFLOW_PAYMENT_PROVIDER=fake.
PAYFLOW_PAYMENT_PROVIDER=fake

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

WORKER_ENABLED=true

# Analytics (opcional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
META_PIXEL_ID=000000000000000

# Admin Access (comma-separated emails)
ADMIN_EMAILS=admin@example.com,owner@example.com

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Demo mode - NEVER enable in production
# Demo mode is for local/portfolio demonstration only.
# When enabled, provider must be fake and demo-login endpoint becomes available.
ENABLE_DEMO_MODE=false
DEMO_USER_EMAIL=demo@payflow.ai
DEMO_USER_PASSWORD=change-me-in-non-local-demo
